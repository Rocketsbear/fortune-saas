# ============================================
# Fortune SaaS - 环境变量配置
# 复制此文件为 .env 并填入实际值
# ====================================

# 环境
ENV=development
DEBUG=true

# 服务器
HOST=0.0.0.0
PORT=8000

# CORS (逗号分隔)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# API 密钥 (生产环境必须修改)
API_KEY=your-secret-api-key-here

# 日志级别
LOG_LEVEL=INFO

# 速率限制 (每分钟请求数)
RATE_LIMIT_PER_MINUTE=10
